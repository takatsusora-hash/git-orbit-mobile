{
  "name": "git-orbit-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Private mobile-first app concept for visualizing the development status of multiple GitHub accounts and repositories in 3D.",
  "scripts": {
    "dev": "next dev",
    "snapshot": "node scripts/generate-snapshots.mjs",
    "build": "next build",
    "build:static": "npm run snapshot && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "github",
    "3d",
    "status",
    "visualization"
  ],
  "author": "takatsusora-hash",
  "license": "UNLICENSED",
  "dependencies": {
    "next": "^15.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.4",
    "typescript": "^5.8.3"
  }
}
